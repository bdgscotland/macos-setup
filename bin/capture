#!/usr/bin/env bash
# =============================================================================
# bin/capture — Export current Mac state into the repo
# =============================================================================
# Two-step process: this dumps a raw snapshot, then you curate it.
# Run this from the repo root.
#
# What it captures:
#   - Brewfile (top-level packages only)
#   - Machine profile (hostname, macOS version, installed state)
#
# What it does NOT capture (by design):
#   - Dotfiles (managed by chezmoi, edit home/ directly)
#   - macOS defaults (managed by macos/*.sh, edit those scripts directly)
#   - Secrets (SSH keys, GPG keys, API tokens)
# =============================================================================
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() { echo -e "${GREEN}[capture]${NC} $1"; }
warn() { echo -e "${YELLOW}[capture]${NC} $1"; }

# ---------------------------------------------------------------------------
# Brewfile
# ---------------------------------------------------------------------------
info "Generating Brewfile from current state..."

CAPTURE_DIR="$SCRIPT_DIR/.capture"
mkdir -p "$CAPTURE_DIR"

brew bundle dump --file="$CAPTURE_DIR/Brewfile.raw" --force 2>/dev/null

info "Raw Brewfile written to .capture/Brewfile.raw"
info "Review it and merge changes into Brewfile manually."
echo ""
echo "  Compare: diff $SCRIPT_DIR/Brewfile $CAPTURE_DIR/Brewfile.raw"
echo "  Extra packages (installed but not in Brewfile):"
diff <(grep '^brew\|^cask\|^tap' "$SCRIPT_DIR/Brewfile" 2>/dev/null | sed 's/#.*//' | sort) \
     <(grep '^brew\|^cask\|^tap' "$CAPTURE_DIR/Brewfile.raw" 2>/dev/null | sed 's/#.*//' | sort) \
     2>/dev/null | grep '^>' | sed 's/^> /    /' || echo "    (none)"

# ---------------------------------------------------------------------------
# Machine profile
# ---------------------------------------------------------------------------
info "Generating machine profile..."

HOSTNAME=$(hostname -s)
MACOS_VERSION=$(sw_vers -productVersion)
MACOS_BUILD=$(sw_vers -buildVersion)
BREW_COUNT=$(brew list --formula 2>/dev/null | wc -l | tr -d ' ')
CASK_COUNT=$(brew list --cask 2>/dev/null | wc -l | tr -d ' ')
CAPTURE_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)

PROFILE_DIR="$SCRIPT_DIR/machines"
mkdir -p "$PROFILE_DIR"

cat > "$PROFILE_DIR/$HOSTNAME.toml" << EOF
# Machine profile: $HOSTNAME
# Generated by bin/capture on $CAPTURE_DATE
# This file tracks what's installed on this specific machine.

[machine]
hostname = "$HOSTNAME"
macos_version = "$MACOS_VERSION"
macos_build = "$MACOS_BUILD"
capture_date = "$CAPTURE_DATE"

[packages]
brew_formula_count = $BREW_COUNT
brew_cask_count = $CASK_COUNT

[languages]
python = "$(python3 --version 2>/dev/null | awk '{print $2}' || echo 'not installed')"
ruby = "$(ruby --version 2>/dev/null | awk '{print $2}' || echo 'not installed')"
node = "$(node --version 2>/dev/null | tr -d 'v' || echo 'not installed')"
rust = "$(rustc --version 2>/dev/null | awk '{print $2}' || echo 'not installed')"
go = "$(go version 2>/dev/null | awk '{print $3}' | tr -d 'go' || echo 'not installed')"
bun = "$(bun --version 2>/dev/null || echo 'not installed')"
EOF

info "Machine profile written to machines/$HOSTNAME.toml"

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
info "Capture complete. Files written to:"
info "  .capture/Brewfile.raw   — raw Brewfile (review before merging)"
info "  machines/$HOSTNAME.toml — machine profile (commit this)"
echo ""
info "Next: review .capture/Brewfile.raw and merge desired changes into Brewfile."
info "Then: git add Brewfile machines/$HOSTNAME.toml && git commit"
